---
import type { HireGiaMode } from "@/lib/ai/hireGiaTypes";

interface Props {
  mode?: HireGiaMode;
}

const { mode = "guide" } = Astro.props;
---

<div class="hire-gia-tabs" role="tablist" aria-label="Portfolio assistant mode">
  <button
    type="button"
    class:list={["hire-gia-tabs__tab", mode === "guide" && "is-active"]}
    role="tab"
    aria-selected={mode === "guide" ? "true" : "false"}
    data-mode="guide"
  >
    Ask about Gia’s work
  </button>
  <button
    type="button"
    class:list={["hire-gia-tabs__tab", mode === "role" && "is-active"]}
    role="tab"
    aria-selected={mode === "role" ? "true" : "false"}
    data-mode="role"
  >
    Match a job description
  </button>
</div>

<style>
  .hire-gia-tabs {
    --hire-gia-tab-surface: transparent;
    --hire-gia-tab-text: color-mix(in srgb, var(--color-text) 90%, transparent);
    --hire-gia-tab-active-bg: #f4f2f1;
    --hire-gia-tab-active-text: #161922;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem;
    padding: 0.3rem;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--color-light) 12%, transparent);
    border-radius: 0.6rem;
    background: var(--hire-gia-tab-surface);
    height: auto;
  }

  :global([data-theme="light"]) .hire-gia-tabs {
    --hire-gia-tab-surface: transparent;
    --hire-gia-tab-text: color-mix(in srgb, var(--color-lightmode-text) 72%, transparent);
    --hire-gia-tab-active-bg: var(--color-lightmode-text);
    --hire-gia-tab-active-text: var(--color-lightmode-body);
  }

  .hire-gia-tabs__tab {
    height: 2.5rem;
    border: 0;
    border-radius: 0.5rem;
    background: transparent;
    color: var(--hire-gia-tab-text);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.55rem 1rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-wrap: balance;
    text-align: center;
  }

  .hire-gia-tabs__tab:hover {
    color: var(--hire-gia-tab-active-text);
  }

  .hire-gia-tabs__tab:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .hire-gia-tabs__tab.is-active {
    color: var(--hire-gia-tab-active-text);
    background: var(--hire-gia-tab-active-bg);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06), 0 8px 24px rgba(0, 0, 0, 0.16);
  }

  @media (max-width: 520px) {
    .hire-gia-tabs {
      grid-template-columns: 1fr;
      height: auto;
    }
  }
</style>
