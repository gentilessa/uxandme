---
import { Badge } from "@astrojs/starlight/components";
---

<section class="hire-gia-response" data-hire-gia-response hidden>
  <div class="hire-gia-response__loading" data-response-loading hidden>
    <p class="hire-gia-response__loading-kicker">Reviewing Gia’s published work...</p>
    <p class="hire-gia-response__loading-copy">This can take a few seconds.</p>

    <div class="hire-gia-response__skeleton-group">
      <span class="hire-gia-response__skeleton hire-gia-response__skeleton--headline"></span>
      <span class="hire-gia-response__skeleton hire-gia-response__skeleton--headline short"></span>
    </div>

    <div class="hire-gia-response__skeleton-group">
      <span class="hire-gia-response__skeleton hire-gia-response__skeleton--line"></span>
      <span class="hire-gia-response__skeleton hire-gia-response__skeleton--line"></span>
      <span class="hire-gia-response__skeleton hire-gia-response__skeleton--line short"></span>
    </div>

    <div class="hire-gia-response__skeleton-card"></div>
    <div class="hire-gia-response__skeleton-card"></div>
  </div>

  <div class="hire-gia-response__content" data-response-content>
  <div class="hire-gia-response__topline">
    <div class="hire-gia-response__session" data-response-session hidden></div>
  </div>

  <div class="hire-gia-response__hero">
    <div class="hire-gia-response__fit-row" data-fit-wrap hidden>
      <Badge
        text=""
        variant="success"
        size="medium"
        class="hire-gia-response__fit-badge"
        data-role-fit-label
      />
    </div>

    <h3 class="hire-gia-response__headline" data-response-headline hidden></h3>
    <p class="hire-gia-response__summary" data-response-summary></p>
  </div>

  <section class="hire-gia-response__section" data-themes-wrap hidden>
    <div class="hire-gia-response__section-heading">
      <h4 data-themes-heading>Connected strengths</h4>
    </div>
    <div class="hire-gia-response__badge-list" data-role-themes></div>
  </section>

  <section class="hire-gia-response__section">
    <div class="hire-gia-response__section-heading">
      <h4 data-evidence-heading>Strongest evidence</h4>
    </div>
    <div class="hire-gia-response__stack" data-role-evidence></div>
  </section>

  <section class="hire-gia-response__section" data-role-gaps-wrap hidden>
    <div class="hire-gia-response__section-heading">
      <h4>Where evidence is thinner</h4>
    </div>
    <div class="hire-gia-response__grid" data-role-gaps></div>
  </section>

  <section class="hire-gia-response__section" data-caveats-wrap hidden>
    <div class="hire-gia-response__section-heading">
      <h4>Important context</h4>
    </div>
    <div class="hire-gia-response__note" data-caveats></div>
  </section>

  <p class="hire-gia-response__limits" data-role-limits hidden></p>

  <p class="hire-gia-response__worth-knowing" data-worth-knowing-wrap hidden>
    <span class="hire-gia-response__worth-knowing-label">Note</span>
    <span class="hire-gia-response__worth-knowing-copy" data-worth-knowing></span>
  </p>

  <div class="hire-gia-response__footer">
    <a class="btn btn-primary hire-gia-response__primary" data-full-review-link hidden href="#">
      Open Full View
    </a>
    <button type="button" class="hire-gia-response__secondary" data-try-again>
      Clear
    </button>
  </div>
  </div>
</section>

<style>
  .hire-gia-response[hidden] {
    display: none !important;
  }

  .hire-gia-response__section[hidden],
  .hire-gia-response__fit-row[hidden],
  .hire-gia-response__topline > [hidden],
  .hire-gia-response__hero > [hidden],
  .hire-gia-response__footer > [hidden] {
    display: none !important;
  }

  .hire-gia-response {
    --hire-gia-response-card: color-mix(in srgb, var(--sl-color-bg-nav) 92%, transparent);
    --hire-gia-response-border: color-mix(in srgb, var(--sl-color-white) 10%, transparent);
    --hire-gia-response-title: var(--sl-color-white);
    --hire-gia-response-text: var(--sl-color-gray-2);
    --hire-gia-response-muted: color-mix(in srgb, var(--sl-color-gray-3) 82%, transparent);
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    flex: 1;
    min-height: 100%;
    min-width: 0;
    max-width: 100%;
    overflow-x: hidden;
  }

  .hire-gia-response__content[hidden],
  .hire-gia-response__loading[hidden] {
    display: none !important;
  }

  .hire-gia-response__loading {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
    align-content: start;
    min-width: 0;
  }

  .hire-gia-response__content {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.875rem;
    min-width: 0;
    max-width: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hire-gia-response__content::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }

  .hire-gia-response__content > * {
    min-width: 0;
  }

  .hire-gia-response__loading-kicker {
    margin: 0;
    color: var(--hire-gia-response-title);
    font-size: 1rem;
    font-weight: 600;
  }

  .hire-gia-response__loading-copy {
    margin: -0.35rem 0 0;
    color: var(--hire-gia-response-muted);
    font-size: 0.9rem;
  }

  .hire-gia-response__skeleton-group {
    display: grid;
    gap: 0.65rem;
  }

  .hire-gia-response__skeleton,
  .hire-gia-response__skeleton-card {
    position: relative;
    overflow: hidden;
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--sl-color-white) 8%, transparent);
  }

  .hire-gia-response__skeleton::after,
  .hire-gia-response__skeleton-card::after {
    content: "";
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--sl-color-white) 10%, transparent) 50%,
      transparent 100%
    );
    animation: hire-gia-shimmer 1.3s ease-in-out infinite;
  }

  .hire-gia-response__skeleton {
    display: block;
    height: 0.9rem;
  }

  .hire-gia-response__skeleton--headline {
    height: 1.45rem;
    width: 100%;
  }

  .hire-gia-response__skeleton--line.short,
  .hire-gia-response__skeleton--headline.short {
    width: 68%;
  }

  .hire-gia-response__skeleton-card {
    min-height: 9rem;
    border: 1px solid var(--hire-gia-response-border);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 70%, transparent);
  }

  .hire-gia-response__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .hire-gia-response__eyebrow,
  .hire-gia-response__section-heading p,
  .hire-gia-response__limits {
    margin: 0;
    color: var(--hire-gia-response-muted);
    font-size: 0.73rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hire-gia-response__session {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.8rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-accent-low) 28%, transparent);
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
  }

  .hire-gia-response__hero {
    display: grid;
    gap: 0.95rem;
    min-width: 0;
  }

  .hire-gia-response__headline {
    margin: 0;
    color: var(--hire-gia-response-title);
    font-size: clamp(1.35rem, 2.2vw, 1.8rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .hire-gia-response__summary {
    margin: 0 0 0.9rem;
    color: var(--hire-gia-response-text);
    font-size: 1rem;
    line-height: 1.72;
    overflow-wrap: anywhere;
  }

  .hire-gia-response__fit-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hire-gia-response :global(.hire-gia-response__fit-badge) {
    border-radius: 999px;
    padding-inline: 0.75rem;
    font-family: var(--sl-font);
    font-weight: 700;
  }

  .hire-gia-response :global(.hire-gia-response__fit-badge.success) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-green-low) 72%, transparent);
  }

  .hire-gia-response :global(.hire-gia-response__fit-badge.caution) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-orange-low) 72%, transparent);
  }

  .hire-gia-response :global(.hire-gia-response__fit-badge.tip) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-purple-low) 72%, transparent);
  }

  .hire-gia-response__section {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 0.9rem;
    border-top: 1px solid var(--hire-gia-response-border);
    min-width: 0;
  }

  .hire-gia-response__section-heading {
    display: grid;
    gap: 0.2rem;
  }

  .hire-gia-response__section-heading h4 {
    margin: 0;
    color: var(--hire-gia-response-title);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hire-gia-response__stack,
  .hire-gia-response__grid,
  .hire-gia-response__badge-list {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
    max-width: 100%;
  }

  .hire-gia-response__badge-list {
    grid-template-columns: repeat(auto-fit, minmax(0, max-content));
    gap: 0.6rem;
    justify-content: start;
    overflow: hidden;
    padding-bottom: 0.2rem;
  }

  .hire-gia-response :global(.hire-gia-response__theme-badge) {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    justify-self: start;
    max-width: 100%;
    border-radius: 999px;
    min-height: 1.875rem;
    padding: 0.35rem 0.8rem;
    font-family: var(--sl-font);
    font-weight: 600;
    font-size: 0.75rem;
    line-height: 1.2;
    border-color: var(--color-primary) !important;
    background: var(--color-primary-gradient) !important;
    color: #fff !important;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-primary) 24%, transparent);
    --sl-color-bg-badge: transparent;
    --sl-color-border-badge: transparent;
    --sl-color-text-badge: #fff;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hire-gia-response__grid {
    grid-template-columns: 1fr;
  }

  .hire-gia-response__note {
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low) 18%, transparent);
    padding: 1rem;
    min-width: 0;
  }

  .hire-gia-response__note p,
  .hire-gia-response__note li {
    margin: 0;
    color: var(--hire-gia-response-text);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .hire-gia-response__worth-knowing {
    display: grid;
    gap: 0.35rem;
    margin: 0 0 14px;
    padding-top: 0.5rem;
    border-top: 1px solid var(--hire-gia-response-border);
    color: var(--hire-gia-response-muted);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .hire-gia-response__worth-knowing-label {
    color: var(--sl-color-text-accent);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hire-gia-response :global(.assistant-evidence-card) {
    display: grid;
    gap: 0.95rem;
    padding: 1.15rem 1.25rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 82%, transparent);
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hire-gia-response :global(.assistant-evidence-card__top) {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.85rem;
    min-width: 0;
  }

  .hire-gia-response :global(.assistant-evidence-card h3) {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 1.1rem;
    line-height: 1.25;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .hire-gia-response :global(.assistant-evidence-card p) {
    margin: 0;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .hire-gia-response :global(.assistant-evidence-card__badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
    font-family: var(--sl-font-system-mono);
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1;
    border: 1px solid transparent;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-white) 8%, transparent);
  }

  .hire-gia-response :global(.assistant-evidence-card__badge--adjacent) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-purple) 52%, var(--sl-color-black) 48%);
    --sl-color-border-badge: color-mix(in srgb, var(--sl-color-purple) 66%, transparent);
    --sl-color-text-badge: var(--sl-color-white);
  }

  .hire-gia-response :global(.assistant-evidence-card__badge--direct) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-blue) 56%, var(--sl-color-black) 44%);
    --sl-color-border-badge: color-mix(in srgb, var(--sl-color-blue) 72%, transparent);
    --sl-color-text-badge: var(--sl-color-white);
  }

  .hire-gia-response :global(.assistant-evidence-card__link) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-white);
    font-weight: 600;
    text-decoration: none;
  }

  .hire-gia-response :global(.assistant-evidence-card__link:hover) {
    color: var(--sl-color-accent-high);
  }

  .hire-gia-response :global(.assistant-article-card) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 82%, transparent);
    color: inherit;
    text-decoration: none;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hire-gia-response :global(.assistant-article-card__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 28%, transparent);
    background: color-mix(in srgb, var(--sl-color-accent-low) 24%, transparent);
    color: var(--sl-color-accent-high);
    font-size: 1rem;
  }

  .hire-gia-response :global(.assistant-article-card__copy) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .hire-gia-response :global(.assistant-article-card__title) {
    color: var(--sl-color-white);
    font-weight: 600;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .hire-gia-response :global(.assistant-article-card__description) {
    color: var(--sl-color-gray-2);
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .hire-gia-response :global(.assistant-article-card__arrow) {
    color: var(--sl-color-gray-3);
    font-size: 1.35rem;
  }

  .hire-gia-response :global(.assistant-article-card:hover .assistant-article-card__arrow) {
    color: var(--sl-color-accent-high);
  }

  .hire-gia-response__radar {
    display: grid;
    gap: 1rem;
  }

  .hire-gia-response__radar-chart {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 15rem;
    border: 1px solid var(--hire-gia-response-border);
    border-radius: 1rem;
    background: var(--hire-gia-response-card);
    padding: 0.75rem;
  }

  .hire-gia-response__radar-chart svg {
    max-width: 100%;
    height: auto;
  }

  .hire-gia-response__radar-list {
    display: grid;
    gap: 0.65rem;
  }

  .hire-gia-response__radar-row {
    display: grid;
    gap: 0.35rem;
  }

  .hire-gia-response__radar-row-top {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--hire-gia-response-title);
    font-size: 0.9rem;
  }

  .hire-gia-response__bar {
    width: 100%;
    height: 0.35rem;
    overflow: hidden;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-white) 8%, transparent);
  }

  .hire-gia-response__bar-fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--sl-color-accent), var(--sl-color-accent-high));
  }

  .hire-gia-response__footer {
    position: sticky;
    bottom: 0;
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1rem;
    padding-bottom: 1rem;
    border-top: 1px solid var(--hire-gia-response-border);
    background: var(--color-lightmode-body);
    min-width: 0;
  }

  @keyframes hire-gia-shimmer {
    100% {
      transform: translateX(100%);
    }
  }

  .hire-gia-response__primary,
  .hire-gia-response__secondary {
    width: auto;
    justify-content: center;
    text-align: center;
    min-height: 2.875rem;
    border-radius: 0.85rem;
    min-width: 0;
  }

  .hire-gia-response__primary {
    width: 100%;
    min-width: 0;
  }

  .hire-gia-response__secondary {
    min-width: 10rem;
  }

  .hire-gia-response__secondary {
    border: 1px solid var(--hire-gia-response-border);
    background: var(--color-lightmode-body);
    color: var(--hire-gia-response-title);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  @media (min-width: 56rem) {
    .hire-gia-response__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
