---
interface Props {
	columns?: number;
	maxWidth?: string;
}

const { columns = 2, maxWidth = "1400px" } = Astro.props;
---

<div class="card-grid" style={`--columns: ${columns}; --max-width: ${maxWidth}`}><slot /></div>

<style>
	@layer starlight.components {
		.card-grid {
			display: grid;
			gap: 1rem;
			grid-template-columns: 1fr;
			margin-top: 1.4rem !important;
		}

		.card-grid > :global(*) {
			margin-top: 0 !important;
		}

		/* Small screens - Always single column */
		@media (max-width: 767px) {
			.card-grid {
				grid-template-columns: 1fr !important;
				gap: 1rem;
			}
		}

		/* Tablet - Max 2 columns */
		@media (min-width: 768px) and (max-width: 1023px) {
			.card-grid {
				grid-template-columns: repeat(min(var(--columns), 2), 1fr);
				gap: 1.5rem;
				max-width: var(--max-width);
				margin: 0 auto;
			}
		}

		/* Desktop - Full column count */
		@media (min-width: 1024px) {
			.card-grid {
				grid-template-columns: repeat(min(var(--columns), 3), 1fr);
				gap: 1.7rem;
				max-width: var(--max-width);
				margin: 0 auto;
			}
		}
	}
</style>
