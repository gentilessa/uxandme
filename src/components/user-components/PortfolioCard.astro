---
import { Badge } from "@astrojs/starlight/components";

interface Props {
  href: string;
  image: string;
  alt: string;
  title: string;
  description: string;
  meta?: string;
  metaItems?: string[];
}

const { href, image, alt, title, description, meta, metaItems = [] } =
  Astro.props as Props;
---

<a href={href} class="portfolio-card">
  <img src={image} alt={alt} loading="lazy" />
  <div class="portfolio-card__body">
    <h3>{title}</h3>
    <p>{description}</p>
    {
      metaItems.length ? (
        <div class="portfolio-card__meta-list" aria-label="Case study problems">
          {metaItems.map((item) => (
            <Badge text={item} variant="note" size="small" />
          ))}
        </div>
      ) : meta ? (
        <span class="portfolio-card__meta-text">{meta}</span>
      ) : null
    }
  </div>
</a>

<style>
  .portfolio-card {
    display: block;
    background: var(--sl-color-black);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: none;
  }
  
  .portfolio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }
  
  .portfolio-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  
  .portfolio-card__body {
    padding: 0 20px 20px;
  }
  
  .portfolio-card__body h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
    color: var(--sl-color-white);
  }
  
  .portfolio-card__body p {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    margin-bottom: 12px;
    line-height: 1.5;
  }
  
  .portfolio-card__meta-text {
    font-size: 0.75rem;
    color: var(--sl-color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .portfolio-card__meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.25rem;
  }

  .portfolio-card__meta-list :global(.note) {
    --sl-color-bg-badge: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    --sl-color-text-badge: var(--sl-color-accent-high);
  }
</style>
