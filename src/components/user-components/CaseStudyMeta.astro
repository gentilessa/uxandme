---
import {
  getTaxonomyLabels,
  type CaseStudyTaxonomyMeta,
} from "@/lib/taxonomy";

interface Props {
  meta?: CaseStudyTaxonomyMeta;
  role?: string;
  capability?: string;
  system?: string;
  platform?: string;
  domain?: string;
}

const entryMeta = Astro.locals.starlightRoute.entry?.data?.meta as
  | CaseStudyTaxonomyMeta
  | undefined;

const {
  meta = entryMeta,
  role: roleProp,
  capability: capabilityProp,
  system: systemProp,
  platform,
  domain,
} = Astro.props as Props;

const taxonomyMode = Boolean(meta);

if (!taxonomyMode && !roleProp) {
  throw new Error("CaseStudyMeta requires taxonomy metadata or explicit props.");
}

const roleValue = taxonomyMode ? meta!.role : roleProp!;
const capabilityValue = taxonomyMode
  ? getTaxonomyLabels("capability", meta!.capability).join(", ")
  : capabilityProp || platform || "—";
const systemValue = taxonomyMode
  ? getTaxonomyLabels("system", meta!.system).join(", ")
  : systemProp || domain || "—";
---

<div class="case-study-meta not-content" role="list">
  <div class="case-study-meta__item" role="listitem">
    <span class="case-study-meta__label">Role</span>
    <strong class="case-study-meta__value">{roleValue}</strong>
  </div>
  <div class="case-study-meta__item" role="listitem">
    <span class="case-study-meta__label">Capability</span>
    <strong class="case-study-meta__value">{capabilityValue}</strong>
  </div>
  <div class="case-study-meta__item" role="listitem">
    <span class="case-study-meta__label">System</span>
    <strong class="case-study-meta__value">{systemValue}</strong>
  </div>
</div>

<style>
  .case-study-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1.25rem;
    margin: 2rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .case-study-meta__item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
    justify-content: flex-start;
    align-self: start;
  }

  .case-study-meta__label {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
  }

  .case-study-meta__value {
    color: var(--sl-color-white);
    font-size: var(--sl-text-xs);
    line-height: 1.45;
    font-weight: 600;
    margin: 0;
  }
</style>
