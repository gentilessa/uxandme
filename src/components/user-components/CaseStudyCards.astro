---
import { getCollection } from "astro:content";
import Grid from "./Grid.astro";
import PortfolioCard from "./PortfolioCard.astro";
import {
  getTaxonomyLabels,
  type CaseStudyTaxonomyMeta,
} from "@/lib/taxonomy";

const groups = [
  { id: "fleet", title: "Fleet", description: "AI-assisted mineral exploration and space-enabled data products." },
  { id: "tradewindow", title: "Tradewindow", description: "Trade, traceability, and complex operational workflow products." },
  { id: "abri", title: "ABRI", description: "AI-assisted decision support for breeding and specialist users." },
  { id: "seequent", title: "Seequent", description: "Geoscience, data platforms, 3D workflows, and product strategy." },
] as const;

type CompanyId = (typeof groups)[number]["id"];

const docs = await getCollection("docs");
const caseStudyEntries = docs
  .filter((entry) => entry.id.startsWith("case-studies/"))
  .filter((entry) => entry.id !== "case-studies/index")
  .filter((entry) => !entry.id.endsWith("/index"))
  .filter((entry) => entry.data.card);

function hrefForEntry(id: string) {
  return `/${id}/`;
}

function cardForEntry(entry: (typeof caseStudyEntries)[number]) {
  const card = entry.data.card!;
  const meta = entry.data.meta as CaseStudyTaxonomyMeta | undefined;
  const problemLabels = meta ? getTaxonomyLabels("problem", meta.problem) : [];

  return {
    company: card.company as CompanyId,
    href: hrefForEntry(entry.id),
    image: card.image,
    alt: card.alt,
    title: entry.data.sidebar?.label || entry.data.title,
    description: card.description,
    metaItems: problemLabels,
  };
}

const cardsByCompany = caseStudyEntries.reduce(
  (acc, entry) => {
    const card = cardForEntry(entry);
    acc[card.company].push(card);
    return acc;
  },
  {
    fleet: [],
    tradewindow: [],
    abri: [],
    seequent: [],
  } as Record<CompanyId, ReturnType<typeof cardForEntry>[]>
);
---

<div class="case-study-groups">
  {
    groups.map((group) => {
      const cards = cardsByCompany[group.id];
      if (!cards.length) return null;

      return (
        <section class="case-study-group">
          <div class="case-study-group__heading">
            <p>{group.title}</p>
            <span>{group.description}</span>
          </div>

          <Grid columns={2} maxWidth="1600px">
            {cards.map((card) => (
              <PortfolioCard
                href={card.href}
                image={card.image}
                alt={card.alt}
                title={card.title}
                description={card.description}
                metaItems={card.metaItems}
              />
            ))}
          </Grid>
        </section>
      );
    })
  }
</div>

<style>
  .case-study-groups {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .case-study-group {
    display: grid;
    gap: 1.5rem;
  }

  .case-study-group__heading {
    max-width: 52rem;
  }

  .case-study-group__heading p {
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: var(--sl-line-height-headings);
    font-weight: 700;
  }

  .case-study-group__heading span {
    display: block;
    margin-top: 0.45rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    line-height: 1.6;
  }
</style>
