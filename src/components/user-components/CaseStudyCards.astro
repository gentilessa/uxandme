---
import { getCollection } from "astro:content";
import Grid from "./Grid.astro";
import PortfolioCard from "./PortfolioCard.astro";
import {
  getTaxonomyLabels,
  type CaseStudyTaxonomyMeta,
} from "@/lib/taxonomy";

type CardConfig = {
  slug: string;
  image: string;
  alt: string;
  description: string;
  title?: string;
};

const cardConfigs: CardConfig[] = [
  {
    slug: "exosphere",
    image: "/images/projects/fleet/hero.png",
    alt: "Exosphere dashboard preview",
    description: "Turning fragmented exploration data into actionable targeting workflows.",
  },
  {
    slug: "central-viewer",
    image: "/images/projects/webviz/hero.png",
    alt: "Central Viewer product preview",
    description: "A cloud-first 3D viewer that made geological collaboration easier and faster.",
  },
  {
    slug: "blocksync",
    image: "/images/projects/blocksync/hero.png",
    alt: "BlockSync product preview",
    description: "Turning spreadsheet-heavy grade control into a cloud-native system of record.",
  },
  {
    slug: "assure-plus",
    image: "/images/projects/assure/hero.png",
    alt: "Assure+ product preview",
    description: "A unified design system across field, admin, and public-facing experiences.",
  },
  {
    slug: "tradewindow",
    image: "/images/projects/tradewindow/tw-dash.png",
    alt: "Cube product preview",
    description: "Designing for the messy handoffs, dependencies, and onboarding paths of global trade.",
    title: "Cube",
  },
  {
    slug: "breedlogic",
    image: "/images/projects/abri/hero.png",
    alt: "BreedLogic product preview",
    description: "Bridging AI and genetics for breeders.",
  },
  {
    slug: "evo",
    image: "/images/projects/evo/evo-research.jpg",
    alt: "Evo product preview",
    description: "Shaping platform strategy for the future of geoscience software.",
  },
  {
    slug: "crm-lead-management",
    image: "/images/projects/seequent/Lead-journey.png",
    alt: "CRM Lead Management product preview",
    description: "Redesigning lead management after a major merger.",
  },
  {
    slug: "north-star",
    image: "/images/projects/north-star/North-Star-Bow-Tie.png",
    alt: "North Star product preview",
    description: "Connecting customer experience to measurement.",
  },
];

const docs = await getCollection("docs");
const caseStudies = new Map(
  docs
    .filter((entry) => entry.id.startsWith("case-studies/") && entry.id !== "case-studies/index")
    .map((entry) => [entry.id.split("/").at(-1), entry] as const)
);

const cards = cardConfigs
  .map((config) => {
    const entry = caseStudies.get(config.slug);
    if (!entry?.data.meta) return null;

    const meta = entry.data.meta as CaseStudyTaxonomyMeta;
    const problemLabels = getTaxonomyLabels("problem", meta.problem);

    return {
      href: `/case-studies/${config.slug}/`,
      image: config.image,
      alt: config.alt,
      title: config.title || entry.data.title,
      description: config.description,
      metaItems: problemLabels,
    };
  })
  .filter(Boolean);
---

<Grid columns={2} maxWidth="1600px">
  {
    cards.map((card) => (
      <PortfolioCard
        href={card!.href}
        image={card!.image}
        alt={card!.alt}
        title={card!.title}
        description={card!.description}
        metaItems={card!.metaItems}
      />
    ))
  }
</Grid>
