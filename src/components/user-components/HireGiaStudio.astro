---
import HireGiaTabs from "./HireGiaTabs.astro";
import HireGiaResponse from "./HireGiaResponse.astro";
import { getAssistantPromptLabels } from "@/lib/taxonomy";

const apiUrl = import.meta.env.PUBLIC_HIRE_GIA_API_URL || "/api/hire-gia";
const bootstrap = { apiUrl };
const guidePrompts = getAssistantPromptLabels(["capability"]).slice(0, 5);
---

<section
  class="hire-gia-studio"
  data-hire-gia-studio
  data-bootstrap={JSON.stringify(bootstrap)}
>
  <div class="hire-gia-studio__query-view" data-hire-gia-query-view>
    <p class="hire-gia-studio__intro" data-hire-gia-intro>
      Review Gia’s work without digging blindly through the portfolio.
      Ask about projects, strengths, experience areas, or paste a job description for an evidence-backed fit read.
    </p>

    <HireGiaTabs mode="guide" />

    <div class="hire-gia-studio__field">
      <label for="hire-gia-question" data-hire-gia-label>What would you like to know?</label>
      <div class="hire-gia-studio__field-card">
        <textarea
          id="hire-gia-question"
          name="hire-gia-question"
          rows="4"
          placeholder="e.g., What experience does Gia have with design systems? Has she worked on accessibility improvements?"
          data-hire-gia-input
          autocomplete="off"
          spellcheck="false"
        ></textarea>

        <div class="hire-gia-studio__chips" data-hire-gia-prompts>
          {
            guidePrompts.map((prompt) => (
              <button
                type="button"
                class="hire-gia-studio__chip"
                data-prompt={prompt}
                aria-pressed="false"
              >
                {prompt}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <p class="hire-gia-studio__helper">
      Ask about projects, strengths, or where the portfolio shows direct evidence.
    </p>

    <div class="hire-gia-studio__error" data-hire-gia-error hidden></div>

    <div class="hire-gia-studio__actions">
      <button type="button" class="btn btn-primary hire-gia-studio__submit" data-hire-gia-submit>
        Get Answer
      </button>
      <button type="button" class="hire-gia-studio__clear" data-hire-gia-clear>
        Clear
      </button>
    </div>
  </div>

  <HireGiaResponse />
</section>

<style>
  .hire-gia-studio {
    --hire-gia-label: var(--color-light);
    --hire-gia-text: var(--color-text);
    --hire-gia-muted: color-mix(in srgb, var(--color-text) 70%, transparent);
    --hire-gia-card-bg: #1b1f26;
    --hire-gia-card-border: color-mix(in srgb, var(--color-light) 12%, transparent);
    --hire-gia-chip-bg: color-mix(in srgb, var(--color-light) 5%, transparent);
    --hire-gia-chip-border: color-mix(in srgb, var(--color-light) 10%, transparent);
    --hire-gia-clear-bg: color-mix(in srgb, var(--sl-color-bg-nav) 76%, transparent);
    --hire-gia-clear-border: color-mix(in srgb, var(--hire-gia-label) 18%, transparent);
    --hire-gia-clear-text: var(--hire-gia-label);
    --hire-gia-footer-bg: var(--color-body);
    --hire-gia-footer-gradient: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-body) 94%, transparent) 74%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
    min-height: 100%;
  }

  .hire-gia-studio__query-view {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
    min-height: 100%;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hire-gia-studio__query-view::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }

  .hire-gia-studio[data-has-result="true"] .hire-gia-studio__query-view {
    display: none;
  }

  .hire-gia-studio[data-has-result="false"] :global(.hire-gia-response),
  .hire-gia-studio:not([data-has-result]) :global(.hire-gia-response) {
    display: none !important;
  }

  :global([data-theme="light"]) .hire-gia-studio {
    --hire-gia-label: var(--color-lightmode-text);
    --hire-gia-text: var(--color-lightmode-text);
    --hire-gia-muted: color-mix(in srgb, var(--color-lightmode-text) 72%, transparent);
    --hire-gia-card-bg: color-mix(in srgb, var(--color-lightmode-body) 98%, var(--color-lightmode-text) 2%);
    --hire-gia-card-border: color-mix(in srgb, var(--color-lightmode-text) 10%, transparent);
    --hire-gia-chip-bg: color-mix(in srgb, var(--color-lightmode-body) 94%, var(--color-lightmode-text) 6%);
    --hire-gia-chip-border: color-mix(in srgb, var(--color-lightmode-text) 10%, transparent);
    --hire-gia-clear-bg: color-mix(in srgb, var(--color-lightmode-body) 92%, var(--color-lightmode-text) 8%);
    --hire-gia-clear-border: color-mix(in srgb, var(--color-lightmode-text) 14%, transparent);
    --hire-gia-clear-text: var(--color-lightmode-text);
    --hire-gia-footer-bg: var(--color-lightmode-body);
    --hire-gia-footer-gradient: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-lightmode-body) 99%, transparent) 74%,
      transparent 100%
    );
  }

  .hire-gia-studio__field {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 0 0 auto;
    min-height: auto;
    transition: gap 0.2s ease;
  }

  .hire-gia-studio__field label,
  .hire-gia-studio__prompts h4 {
    margin: 0;
    color: var(--hire-gia-label);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .hire-gia-studio__field-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.15rem;
    border: 1px solid var(--hire-gia-card-border);
    border-radius: 1rem;
    background: var(--hire-gia-card-bg);
    overflow: hidden;
    transition: padding 0.2s ease, min-height 0.2s ease;
  }

  .hire-gia-studio textarea {
    width: 100%;
    display: block;
    flex: 1 1 auto;
    min-height: 9rem;
    height: 9rem;
    position: relative;
    z-index: 1;
    resize: vertical;
    border: 0;
    background: transparent;
    color: var(--hire-gia-text);
    font: inherit;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 0;
  }

  .hire-gia-studio textarea::placeholder {
    color: var(--hire-gia-muted);
    font-style: italic;
  }

  .hire-gia-studio textarea:focus {
    outline: none;
  }

  .hire-gia-studio__intro {
    margin: 0;
    color: var(--hire-gia-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 30rem;
    text-wrap: pretty;
    transition: opacity 0.18s ease, max-height 0.18s ease, margin 0.18s ease;
  }

  .hire-gia-studio__helper {
    margin: 0;
    color: color-mix(in srgb, var(--hire-gia-muted) 88%, transparent);
    font-size: 0.75rem;
    line-height: 1.35;
    padding-left: 1.75rem;
    position: relative;
  }

  .hire-gia-studio__helper::before {
    content: "i";
    position: absolute;
    left: 0;
    top: 0.05rem;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1;
  }

  .hire-gia-studio__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 2;
    transition: opacity 0.18s ease, max-height 0.18s ease, margin 0.18s ease;
  }

  :global(.hire-gia-studio__chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 1.875rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--hire-gia-chip-border);
    border-radius: 999px;
    background: var(--hire-gia-chip-bg);
    color: var(--hire-gia-text);
    font: inherit;
    font-size: 0.75rem;
    line-height: 1.2;
    cursor: pointer;
    pointer-events: auto;
    user-select: none;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  :global(.hire-gia-studio__chip[aria-pressed="true"]),
  :global(.hire-gia-studio__chip.is-selected) {
    color: #fff !important;
    border-color: var(--color-primary) !important;
    background: var(--color-primary-gradient) !important;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-primary) 24%, transparent);
  }

  .hire-gia-studio__error {
    border: 1px solid color-mix(in srgb, #ff7b7b 35%, transparent);
    border-radius: 0.9rem;
    padding: 0.8rem 0.9rem;
    color: #ffb6b6;
    font-size: 0.9rem;
    line-height: 1.5;
    background: color-mix(in srgb, #ff7b7b 10%, transparent);
  }

  :global(.hire-gia-studio__actions) {
    position: sticky;
    bottom: 0;
    z-index: 3;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: auto;
    padding-top: 1rem;
    padding-bottom: 1rem;
    background: var(--hire-gia-footer-gradient);
  }

  :global(.hire-gia-studio__submit) {
    flex: 1;
    width: 100%;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    justify-content: center;
    text-align: center;
    min-height: 2.875rem;
    height: 2.875rem;
    border-radius: 0.5rem;
  }

  .hire-gia-studio[data-has-result="true"] .hire-gia-studio__query-view {
    display: none;
  }

  :global(.hire-gia-studio__clear) {
    min-height: 2.875rem;
    height: 2.875rem;
    min-width: 10rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.1rem;
    text-align: center;
    border-radius: 0.75rem;
    border: 1px solid var(--hire-gia-clear-border);
    background: var(--hire-gia-clear-bg);
    color: var(--hire-gia-clear-text);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  .hire-gia-studio[data-has-result="true"] .hire-gia-studio__intro,
  .hire-gia-studio[data-mode="role"] .hire-gia-studio__chips {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    margin: 0;
    pointer-events: none;
  }

  .hire-gia-studio[data-has-result="true"] .hire-gia-studio__field-card {
    padding: 0.9rem 1rem;
  }

  .hire-gia-studio[data-has-result="true"] textarea {
    min-height: 4.5rem;
    height: 4.5rem;
  }

  @media (max-width: 640px) {
    .hire-gia-studio {
      gap: 0.85rem;
    }

    .hire-gia-studio__field-card {
      min-height: 0;
    }

    .hire-gia-studio textarea {
      min-height: 8rem;
      height: 8rem;
    }

    :global(.hire-gia-studio__actions) {
      padding-top: 0.6rem;
      flex-wrap: wrap;
    }

    :global(.hire-gia-studio__submit),
    :global(.hire-gia-studio__clear) {
      width: 100%;
      min-width: 0;
    }
  }

  :global(.hire-gia-sheet__body) {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  :global(.hire-gia-sheet__body::-webkit-scrollbar) {
    width: 0;
    height: 0;
    display: none;
  }
</style>

<script>
  import { initHireGiaStudios } from "../../lib/ai/hireGiaStudioClient";

  initHireGiaStudios();
</script>
