---
const { quote, author, role, avatar } = Astro.props;
---

<blockquote class="testimonial-card">
  <p set:html={quote}></p>
  <footer>
    <img src={avatar} alt={author} />
    <div>
      <strong>{author}</strong>
      <span>{role}</span>
    </div>
  </footer>
</blockquote>

<style>
  .testimonial-card {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
    border-radius: 1rem;
    padding: 2rem;
    margin: 48px auto;
  }
  
  .testimonial-card p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--sl-color-gray-1);
    font: italic 400 20px/28px 'Playfair Display', serif;
    margin: 0 !important;
  }

  .testimonial-card p:empty {
    display: none;
  }
  
  .testimonial-card footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }
  
  .testimonial-card footer img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .testimonial-card footer div {
    display: flex;
    flex-direction: column;
  }
  
  .testimonial-card footer strong {
    color: var(--sl-color-white);
    font-size: 1rem;
    font-weight: 600;
  }
  
  .testimonial-card footer span {
    color: var(--sl-color-gray-2);
    font-size: 0.875rem;
  }
</style>
