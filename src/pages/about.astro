---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Grid from "@/components/user-components/Grid.astro";
import NewCard from "@/components/user-components/NewCard.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";

const focusAreas = [
  {
    title: "Complex product design",
    icon: "layers",
    iconColor: "#8eb3ff",
    body: "Turning dense workflows, specialist tools, and operational complexity into clearer product experiences.",
  },
  {
    title: "Systems thinking",
    icon: "layout",
    iconColor: "#c59cff",
    body: "Creating reusable patterns, shared language, and design structures that help products scale coherently.",
  },
  {
    title: "AI-assisted workflows",
    icon: "brain",
    iconColor: "#ff8ea1",
    body: "Exploring how AI can support decisions, insight generation, and human-in-the-loop product experiences.",
  },
];

const experience = [
  { title: "Lead Product Designer", dates: "FEB 25 - Present", company: "Fleet Space Technologies", side: "right" },
  { title: "Lead UX Designer", dates: "JAN 24 - OCT 24", company: "ABRI", side: "left" },
  { title: "Lead Product Designer", dates: "MAR 23 - JAN 24", company: "Tradewindow", side: "right" },
  { title: "Manager, User Experience & Research", dates: "JAN 20 - MAR 24", company: "Bentley Systems", side: "left" },
];
---

<BaseLayout
  title="About Gia Romano"
  description="About Gia Romano, Lead Product Designer for complex SaaS, specialist platforms, data-rich systems, and AI-assisted workflows."
>
  <main class="about-page" data-pagefind-body>
    <section class="about-hero">
      <p class="about-hero__eyebrow">About</p>
      <div class="about-hero__grid">
        <div class="about-hero__copy">
          <h1>Designing products for complexity.</h1>
          <p class="about-hero__lede">
            I'm Gia Romano, a Lead Product Designer with a background in enterprise SaaS,
            specialist platforms, and data-rich systems.
          </p>
        </div>
        <div class="about-hero__panel">
          <p>
            Most of the work I'm drawn to sits well beyond surface-level UX:
            complex workflows, dense information, operational tools, technical users,
            and products that need to support real decisions, not just clean interfaces.
          </p>
        </div>
      </div>
    </section>

    <section class="about-narrative">
      <p>
        Over the years I've worked across web, mobile, and desktop experiences,
        leading design in environments where the challenge is rarely just visual.
        It is structural. How should the product work? What needs to be visible?
        What needs review? What helps users act with confidence? How do you make
        a technically dense system feel clear without making it shallow?
      </p>

      <p>
        I've built design systems, led UX across multiple product areas, improved
        design maturity inside organisations, and worked closely with product
        managers, engineers, and subject matter experts to turn specialist tools
        into clearer, more intuitive experiences.
      </p>

      <p>
        I care about products that do something real. Products that help people
        interpret information, navigate ambiguity, and move through work with more
        clarity and less friction.
      </p>
    </section>

    <div class="content-panel">
      <div class="sl-container">
        <Section title="What I Bring" description="The through-line across my work is making difficult systems easier to reason about.">
          <Grid columns={3}>
            {focusAreas.map((item) => (
              <NewCard icon={item.icon} title={item.title} iconColor={item.iconColor}>
                <p>{item.body}</p>
              </NewCard>
            ))}
          </Grid>
        </Section>
      </div>
    </div>

    <div class="content-panel">
      <div class="sl-container">
        <Section title="Work History" description="Selected recent roles across product design, UX leadership, complex SaaS, specialist tools, and data-rich platforms.">
          <ExperienceTimeline items={experience} />
        </Section>
      </div>
    </div>

    <section class="about-cta">
      <p>
        For a fuller view of my roles and experience, visit my
        <a href="https://www.linkedin.com/in/giaromano/">LinkedIn profile</a>.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    padding-top: calc(var(--sl-nav-height) + 6rem);
  }

  .about-hero,
  .about-narrative,
  .about-cta {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    padding-inline: var(--sl-content-pad-x);
  }

  .about-hero {
    padding-bottom: clamp(4rem, 9vw, 7rem);
  }

  .about-hero__eyebrow {
    margin: 0 0 2rem;
    color: var(--sl-color-accent);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .about-hero h1 {
    max-width: 11ch;
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
  }

  .about-hero__lede {
    max-width: 42rem;
    margin: 2rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    line-height: 1.55;
  }

  .about-hero__panel {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 1.25rem;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--sl-color-accent-low) 45%, transparent), transparent 60%),
      var(--sl-color-gray-6);
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  .about-hero__panel p,
  .about-narrative p,
  .about-cta p {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(1.1rem, 1.8vw, 1.45rem);
    line-height: 1.75;
  }

  .about-narrative {
    display: grid;
    gap: 1.4rem;
    max-width: 58rem;
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  .content-panel {
    padding: clamp(3rem, 3vw, 5rem) 0;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .about-page :global(.section) {
    padding-block: calc(var(--spacing) + 8px) !important;
  }

  .sl-container {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    padding: 0 var(--sl-content-pad-x);
  }

  .about-cta {
    padding-block: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--sl-color-hairline);
    text-align: center;
  }

  .about-cta a {
    color: var(--sl-color-accent);
    text-decoration-color: color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
    text-underline-offset: 0.25em;
  }

  @media (max-width: 760px) {
    .about-page {
      padding-top: calc(var(--sl-nav-height) + 3rem);
    }

    .about-hero__grid {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .about-hero h1 {
      max-width: 9ch;
    }
  }
</style>
