---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Grid from "@/components/user-components/Grid.astro";
import NewCard from "@/components/user-components/NewCard.astro";
import Section from "@/components/Section.astro";
import Hero from "@/components/Hero.astro";
import PortfolioCard from "@/components/user-components/PortfolioCard.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";
import Testimonial from "@/components/Testimonial.astro";

const featuredStudies = [
  {
    href: "/case-studies/exosphere/",
    image: "/images/projects/fleet/hero.png",
    alt: "Exosphere dashboard",
    title: "Exosphere",
    description: "Turning fragmented exploration data into actionable targeting workflows.",
    meta: "Geoscience • AI targeting",
  },
  {
    href: "/case-studies/breedlogic/",
    image: "/images/projects/abri/hero.png",
    alt: "BreedLogic project preview",
    title: "BreedLogic",
    description: "Bridging AI and genetics for breeders.",
    meta: "Genetics • Decision support",
  },
];

const strengths = [
  { title: "AI-assisted workflows", icon: "brain", iconColor: "#ff8ea1", body: "Designing human-centred flows that make AI outputs more usable, explainable, and actionable." },
  { title: "Complex workflows", icon: "git-branch", iconColor: "#8eb3ff", body: "Simplifying multi-step, technical processes into scannable, linear user journeys." },
  { title: "Data visualisation", icon: "bar-chart", iconColor: "#8de1b2", body: "Clarifying dense information through interfaces built for insight and decision-making." },
  { title: "3D and specialist platforms", icon: "box", iconColor: "#ffd27c", body: "Creating usable workflows for technically deep, data-rich, and spatial products." },
  { title: "Enterprise SaaS systems", icon: "layers", iconColor: "#7cc6ff", body: "Designing structured, scalable experiences for complex business software." },
  { title: "Design systems and delivery", icon: "layout", iconColor: "#c59cff", body: "Establishing the patterns, components, and collaboration needed for consistent execution." },
];

const experience = [
  { title: "Lead Product Designer", dates: "FEB 25 - Present", company: "Fleet Space Technologies", side: "right" },
  { title: "Lead UX Designer", dates: "JAN 24 - OCT 24", company: "ABRI", side: "left" },
  { title: "Lead Product Designer", dates: "MAR 23 - JAN 24", company: "Tradewindow", side: "right" },
  { title: "Manager, User Experience & Research", dates: "JAN 20 - MAR 24", company: "Bentley Systems", side: "left" },
];
---

<BaseLayout
  title="Product Design Documentation"
  description="Product design case studies for complex SaaS, AI-assisted workflows, and systems-led product work."
  hasHeroBg
>
  <div class="main-frame">
    <div class="container flex relative">
      <div class="content-container">
        <div class="main-pane">
          <main data-pagefind-body lang="en" dir="ltr">
            <!-- Hero -->
            <Hero />

            <!-- Featured Case Studies -->
            <div class="content-panel">
              <div class="sl-container">
                <Section title="Featured Case Studies" description="Selected case studies demonstrating systems thinking and complex UI design.">
                  <Grid columns={2}>
                    {featuredStudies.map(study => (
                      <PortfolioCard {...study} />
                    ))}
                  </Grid>
                </Section>
              </div>
            </div>

            <!-- What I Design -->
            <div class="content-panel">
              <div class="sl-container">
                <Section title="What I Design" description="Core competencies in complex product environments.">
                  <Grid columns={3}>
                    {strengths.map(skill => (
                      <NewCard icon={skill.icon} title={skill.title} iconColor={skill.iconColor}>
                        <p>{skill.body}</p>
                      </NewCard>
                    ))}
                  </Grid>
                </Section>
              </div>
            </div>

            <!-- Experience -->
            <div class="content-panel">
              <div class="sl-container">
                <Section title="Experience">
                  <ExperienceTimeline items={experience} />
                </Section>
              </div>
            </div>

            <!-- Testimonial -->
            <div class="content-panel">
              <div class="sl-container">
                <Testimonial
                  quote="Gia has a rare ability to take incredibly dense technical requirements and translate them into interfaces that feel lightweight and obvious. Her work on our AI copilot didn't just improve usability; it defined our product strategy for the year."
                  author="Hemant Chaurasia"
                  role="CTPO at Fleet Space Technologies"
                  avatar="/images/portraits/hemant.jpg"
                />
              </div>
            </div>
          </main>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .content-panel {
    padding: 16px 0;
    border-top: 1px solid var(--sl-color-hairline);
  }
  
  .sl-container {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    padding: 0 var(--sl-content-pad-x);
  }
</style>
