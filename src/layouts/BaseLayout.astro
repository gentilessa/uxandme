---
import "../styles/global.css";
import "../styles/custom.css";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import HireGiaLauncher from "@/components/HireGiaLauncher.astro";

interface Props {
  title: string;
  description: string;
  activeNav?: "work" | "articles" | "about" | "hire";
  bodyClass?: string;
  pageClass?: string;
  hasHeroBg?: boolean;
}

const {
  title,
  description,
  activeNav,
  bodyClass = "astro-bguv2lll",
  pageClass = "page sl-flex page--no-section-nav astro-cqnilpoy",
  hasHeroBg = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`${title} | UX & Me`}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:locale" content="en" />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="UX & Me" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192x192.png" />
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("starlight-theme");
          const theme =
            savedTheme === "light" || savedTheme === "dark"
              ? savedTheme
              : window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {}
      })();
    </script>
    <link rel="stylesheet" href="/_astro/print.DNXP8c50.css" media="print" />
    <link rel="stylesheet" href="/_astro/common.CrIw9rsU.css" />
    <link rel="stylesheet" href="/_astro/Code.CkWzL61B.css" />
    <link rel="stylesheet" href="/_astro/ec.v4551.css" />
  </head>
  <body class={bodyClass}>
    <div class={pageClass}>
      {
        hasHeroBg && (
          <div class="hero-bg">
            <img
              src="/images/hero-bg-light.png"
              alt="Hero Background Light"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="1920"
              height="856"
              class="dark:hidden w-full h-full object-cover"
            />
            <img
              src="/images/hero-bg-dark.png"
              alt="Hero Background Dark"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="1920"
              height="820"
              class="hidden dark:block w-full h-full object-cover"
            />
          </div>
        )
      }
      <SiteHeader activeNav={activeNav} />
      <div class="main-frame">
        <div class="container flex relative">
          <div class="content-container">
            <div class="main-pane">
              <main data-pagefind-body class="astro-bguv2lll" lang="en" dir="ltr">
                <slot />
              </main>
            </div>
          </div>
        </div>
      </div>
      <SiteFooter />
      <HireGiaLauncher />
    </div>
    <script type="module" src="/_astro/page.BIhdncjw.js"></script>
  </body>
</html>
